POSTGRES_PASSWORD=change-me
JWT_SECRET_KEY=change-this-to-a-long-random-string
ENV=production

# Frontend API base URL used in development.
# In Docker/EC2, the frontend is fronted by nginx on port 80 and
# talks to the backend via the internal /api proxy, so this is
# typically overridden by NEXT_PUBLIC_API_BASE_URL=/api at build time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Scanner: Shield + Guard (set to "false" to disable)
ENABLE_SHIELD=true
ENABLE_GUARD=true

